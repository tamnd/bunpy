// Workspace for local development. scripts/sync-deps.sh clones
// gopapy, gocopy, and goipy into ./.deps at pinned commits. CI
// runs the script before any go command. The .deps tree is in
// .gitignore so it never lands in the repo.
go 1.26

use (
	.
	./.deps/gocopy
	./.deps/goipy
	./.deps/gopapy
)
